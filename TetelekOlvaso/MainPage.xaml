<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TetelekOlvaso.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Főmenü"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <VerticalStackLayout Spacing="4" Margin="0,10,0,10">
                <Label
                    Text="📘 Tételolvasó"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#111827" />

                <Label
                    Text="Tételek és gyakorlók egy helyen"
                    FontSize="14"
                    TextColor="#6B7280" />
            </VerticalStackLayout>

            <Frame
                Padding="18"
                CornerRadius="22"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="False">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OpenTetelekTapped" />
                </Frame.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="📚" FontSize="34" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Tételek" FontSize="20" FontAttributes="Bold" TextColor="#111827" />
                        <Label Text="Olvasd el a kidolgozott tételeket" FontSize="14" TextColor="#6B7280" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame
                Padding="18"
                CornerRadius="22"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="False">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OpenQuizTapped" />
                </Frame.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="⏳" FontSize="34" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Évszám gyakorló" FontSize="20" FontAttributes="Bold" TextColor="#111827" />
                        <Label Text="Válassz tételt, és gyakorold az évszámokat" FontSize="14" TextColor="#6B7280" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame
                Padding="18"
                CornerRadius="22"
                BackgroundColor="White"
                BorderColor="#E5E7EB"
                HasShadow="False">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OpenPersonQuizTapped" />
                </Frame.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="👑" FontSize="34" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Személyek és cselekedetek" FontSize="20" FontAttributes="Bold" TextColor="#111827" />
                        <Label Text="Királyok, vezetők, intézkedések és fontos tettek" FontSize="14" TextColor="#6B7280" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>