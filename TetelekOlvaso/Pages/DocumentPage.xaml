<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TetelekOlvaso.Pages.DocumentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dokumentum"
    BackgroundColor="#F9FAFB">

    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="14">

        <Frame
            Padding="16"
            CornerRadius="18"
            BackgroundColor="White"
            BorderColor="#E5E7EB"
            HasShadow="False">

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="📖 Megnyitott tétel"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="#4F46E5" />

                <Label
                    x:Name="TitleLabel"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="#111827"
                    LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </Frame>

        <Frame
            Grid.Row="1"
            Padding="16"
            CornerRadius="18"
            BackgroundColor="White"
            BorderColor="#E5E7EB"
            HasShadow="False">

            <ScrollView>
                <Label
                    x:Name="ContentLabel"
                    FontSize="17"
                    TextColor="#1F2937"
                    LineHeight="1.4" />
            </ScrollView>
        </Frame>

    </Grid>
</ContentPage>